{
  "expo": {
    "name": "skrepachap",
    "slug": "skrepachap",
    "version": "1.0.1",
    "android": {
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "../../assets/images/logo 1.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.countrymaterialslimited.skrepachap",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "../../assets/images/logo 1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload waste images.",
          "cameraPermission": "The app accesses your camera to let you take waste images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8aed1691-6267-44b9-a7fe-bca8e704abea"
      }
    },
    "ios": {
      "bundleIdentifier": "com.countrymaterialslimited.skrepachap"
    }
  }
}
